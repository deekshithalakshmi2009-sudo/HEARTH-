# Hearth environment variables
# Copy this file to .env and fill in your values.
# No Mapbox token needed — the map uses free OpenStreetMap tiles via Leaflet.

VITE_API_URL=http://localhost:8000   # Backend REST API base URL (use https:// in production)
VITE_WS_URL=ws://localhost:8000      # Backend WebSocket base URL (use wss:// in production)
